# Copia questo file in .env e inserisci la tua chiave API Anthropic
# Ottienila su: https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=sk-ant-...

# (Opzionale) Directory dove vengono salvati utenti e ricette.
# Default: ./data/ accanto a server.py
# Imposta un path assoluto su server per disaccoppiare i dati dal codice.
# DATA_DIR=/var/lib/ricette
